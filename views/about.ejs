<%- include('partials/header') %>

<!-- ─── Page Hero ─────────────────────────────────────────────────────────── -->
<section class="page-hero">
  <div class="container text-center">
    <h1 class="page-hero-title">About FixNow</h1>
    <p class="page-hero-sub">Pakistan's most trusted platform for home service professionals.</p>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb justify-content-center">
        <li class="breadcrumb-item"><a href="/">Home</a></li>
        <li class="breadcrumb-item active">About</li>
      </ol>
    </nav>
  </div>
</section>

<!-- ─── Story Section ─────────────────────────────────────────────────────── -->
<section class="section-pad">
  <div class="container">
    <div class="row align-items-center g-5">
      <div class="col-lg-6" data-animate="fade-up">
        <div class="about-img-wrap">
          <img
            src="https://images.unsplash.com/photo-1521791136064-7986c2920216?w=700&q=80"
            alt="Our Team"
            class="about-img img-fluid rounded-4"
          />
          <div class="about-img-badge">
            <strong>Est. 2021</strong>
            <span>Lahore, Pakistan</span>
          </div>
        </div>
      </div>
      <div class="col-lg-6" data-animate="fade-up" style="animation-delay:150ms">
        <span class="section-tag">Our Story</span>
        <h2 class="section-title mt-2">We Make Home Repairs Effortless</h2>
        <p class="text-muted lh-lg mt-3">
          FixNow was founded in 2021 with a simple idea: finding a reliable plumber, electrician, or AC technician
          shouldn't be stressful. We built a platform that connects verified professionals with homeowners — cutting
          out the middleman and the guesswork.
        </p>
        <p class="text-muted lh-lg">
          Today, we serve thousands of homes across Lahore, Karachi, and Islamabad. Every professional on our
          platform is background-checked, skill-verified, and rated by real customers.
        </p>
        <div class="about-stats-row mt-4">
          <div class="about-stat">
            <span class="stat-big">10K+</span>
            <span>Jobs Done</span>
          </div>
          <div class="about-stat">
            <span class="stat-big">500+</span>
            <span>Experts</span>
          </div>
          <div class="about-stat">
            <span class="stat-big">3</span>
            <span>Cities</span>
          </div>
          <div class="about-stat">
            <span class="stat-big">4.9★</span>
            <span>Rating</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ─── Mission & Vision ──────────────────────────────────────────────────── -->
<section class="section-pad bg-light-custom">
  <div class="container">
    <div class="section-header" data-animate="fade-up">
      <span class="section-tag">Our Purpose</span>
      <h2 class="section-title">Mission & Vision</h2>
    </div>
    <div class="row g-4 mt-3">
      <div class="col-md-6" data-animate="fade-up">
        <div class="mv-card mission-card">
          <div class="mv-icon"><i class="bi bi-bullseye"></i></div>
          <h4>Our Mission</h4>
          <p>
            To make professional home services accessible, affordable, and stress-free for every household in
            Pakistan — through technology, trust, and transparency.
          </p>
          <ul class="mv-list">
            <li><i class="bi bi-check2-circle"></i> Simplify service booking for homeowners</li>
            <li><i class="bi bi-check2-circle"></i> Create dignified income for skilled tradespeople</li>
            <li><i class="bi bi-check2-circle"></i> Build a verified marketplace of home professionals</li>
          </ul>
        </div>
      </div>
      <div class="col-md-6" data-animate="fade-up" style="animation-delay:100ms">
        <div class="mv-card vision-card">
          <div class="mv-icon"><i class="bi bi-eye"></i></div>
          <h4>Our Vision</h4>
          <p>
            To become South Asia's most trusted home services ecosystem — where quality and reliability are
            standard, not premium.
          </p>
          <ul class="mv-list">
            <li><i class="bi bi-check2-circle"></i> Expand to 20+ cities by 2026</li>
            <li><i class="bi bi-check2-circle"></i> Achieve same-day service in all major cities</li>
            <li><i class="bi bi-check2-circle"></i> Train 5,000+ certified home professionals</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ─── Team Section ──────────────────────────────────────────────────────── -->
<section class="section-pad">
  <div class="container">
    <div class="section-header" data-animate="fade-up">
      <span class="section-tag">The People</span>
      <h2 class="section-title">Meet Our Team</h2>
    </div>
    <div class="row g-4 mt-2 justify-content-center">
      <% const team = [
        { name: 'Usman Tariq', role: 'Founder & CEO', img: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=300&q=80' },
        { name: 'Ayesha Khan', role: 'Head of Operations', img: 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=300&q=80' },
        { name: 'Bilal Ahmed', role: 'Lead Developer', img: 'https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=300&q=80' },
        { name: 'Sana Malik', role: 'Customer Experience', img: 'https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=300&q=80' }
      ]; %>
      <% team.forEach(function(member, i) { %>
      <div class="col-sm-6 col-lg-3" data-animate="fade-up" style="animation-delay: <%= i * 80 %>ms">
        <div class="team-card">
          <div class="team-img-wrap">
            <img src="<%= member.img %>" alt="<%= member.name %>" class="team-img" />
            <div class="team-social">
              <a href="#"><i class="bi bi-linkedin"></i></a>
              <a href="#"><i class="bi bi-twitter-x"></i></a>
            </div>
          </div>
          <h6 class="team-name"><%= member.name %></h6>
          <span class="team-role"><%= member.role %></span>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ─── CTA ───────────────────────────────────────────────────────────────── -->
<section class="cta-section">
  <div class="container">
    <div class="cta-box text-center">
      <h2>Ready to Experience FixNow?</h2>
      <p>Book your first service today and see why 10,000+ homeowners trust us.</p>
      <div class="cta-actions justify-content-center">
        <a href="/register" class="btn btn-cta-primary">Book a Service</a>
        <a href="/services" class="btn btn-cta-outline">Browse Services</a>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
